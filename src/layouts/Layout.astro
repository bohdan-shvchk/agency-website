---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const {
  title,
  description = 'Webflow Development Agency for Fast, Scalable, High-Performance Websites',
  image = '/og-image.png',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary Meta -->
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.site)} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, Astro.site)} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

    <!-- Schema.org: Agency -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "ProfessionalService",
        "name": "Your Agency",
        "description": "Webflow Development Agency for Fast, Scalable, High-Performance Websites",
        "url": "https://yourdomain.com",
        "serviceType": ["Webflow Development", "Web Automation", "Website Maintenance"]
      }
    </script>
  </head>
  <body class="min-h-screen">
    <header class="fixed top-0 left-0 right-0 z-50 border-b border-white/10 bg-[#0a0a0a]/80 backdrop-blur-md">
      <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href="/" class="text-white font-bold text-xl tracking-tight hover:opacity-80">
          your.agency
        </a>
        <nav class="hidden md:flex items-center gap-8">
          <a href="/services" class="text-sm text-white/60 hover:text-white">Services</a>
          <a href="/projects" class="text-sm text-white/60 hover:text-white">Work</a>
          <a href="/blog" class="text-sm text-white/60 hover:text-white">Blog</a>
          <a href="/agency" class="text-sm text-white/60 hover:text-white">Agency</a>
          <a href="/pricing" class="text-sm text-white/60 hover:text-white">Pricing</a>
        </nav>
        <a href="/contact" class="bg-white text-black text-sm font-semibold px-5 py-2 rounded-full hover:bg-white/90">
          Let's talk
        </a>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="border-t border-white/10 mt-24">
      <div class="max-w-6xl mx-auto px-6 py-16 grid grid-cols-1 md:grid-cols-4 gap-10">
        <div class="md:col-span-2">
          <a href="/" class="text-white font-bold text-xl">your.agency</a>
          <p class="mt-3 text-sm text-white/50 max-w-xs">
            Webflow development for fast, scalable, high-performance websites.
          </p>
          <div class="mt-6 flex gap-4">
            <a href="https://linkedin.com" target="_blank" rel="noopener" class="text-white/40 hover:text-white text-sm">LinkedIn</a>
            <a href="https://twitter.com" target="_blank" rel="noopener" class="text-white/40 hover:text-white text-sm">Twitter</a>
            <a href="https://clutch.co" target="_blank" rel="noopener" class="text-white/40 hover:text-white text-sm">Clutch</a>
          </div>
        </div>
        <div>
          <p class="text-xs font-semibold text-white/30 uppercase tracking-widest mb-4">Services</p>
          <ul class="space-y-2">
            <li><a href="/services#development" class="text-sm text-white/60 hover:text-white">Webflow Development</a></li>
            <li><a href="/services#integrations" class="text-sm text-white/60 hover:text-white">Integrations & Automation</a></li>
            <li><a href="/services#support" class="text-sm text-white/60 hover:text-white">Support & Maintenance</a></li>
          </ul>
        </div>
        <div>
          <p class="text-xs font-semibold text-white/30 uppercase tracking-widest mb-4">Company</p>
          <ul class="space-y-2">
            <li><a href="/agency" class="text-sm text-white/60 hover:text-white">About</a></li>
            <li><a href="/projects" class="text-sm text-white/60 hover:text-white">Work</a></li>
            <li><a href="/blog" class="text-sm text-white/60 hover:text-white">Blog</a></li>
            <li><a href="/contact" class="text-sm text-white/60 hover:text-white">Contact</a></li>
            <li><a href="/privacy-policy" class="text-sm text-white/60 hover:text-white">Privacy</a></li>
          </ul>
        </div>
      </div>
      <div class="max-w-6xl mx-auto px-6 pb-8 flex items-center justify-between">
        <p class="text-xs text-white/30">© {new Date().getFullYear()} Your Agency. All rights reserved.</p>
        <p class="text-xs text-white/30">Built with Astro + Vercel</p>
      </div>
    </footer>
  </body>
</html>
