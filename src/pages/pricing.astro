---
import Layout from '../layouts/Layout.astro';

const plans = [
  {
    name: 'Starter',
    price: '$2,500',
    unit: 'one-time',
    desc: 'For startups that need a clean, fast landing page — fast.',
    features: [
      'Up to 5 pages',
      'Webflow CMS setup',
      'Mobile-responsive',
      'SEO foundation (meta, sitemap)',
      'GA4 + Clarity setup',
      '2-week post-launch support',
    ],
    cta: 'Get started',
    highlight: false,
  },
  {
    name: 'Growth',
    price: '$5,500',
    unit: 'one-time',
    desc: 'A full marketing site built to rank, convert, and scale.',
    features: [
      'Up to 15 pages',
      'Blog / CMS collections',
      'Custom animations & interactions',
      'Schema.org markup',
      '1 integration (CRM or email)',
      'Figma-to-Webflow translation',
      '4-week post-launch support',
    ],
    cta: 'Most popular',
    highlight: true,
  },
  {
    name: 'Scale',
    price: 'Custom',
    unit: 'project-based',
    desc: 'Complex builds, deep integrations, and ongoing partnerships.',
    features: [
      'Unlimited pages',
      'Multiple CMS collections',
      'Full automation setup',
      'AI agent integrations',
      'Priority support retainer',
      'Quarterly performance reviews',
    ],
    cta: 'Let\'s talk',
    highlight: false,
  },
];

const retainer = [
  { name: 'Basic', price: '$500/mo', features: ['Up to 4 hours of changes/mo', 'Bug fixes', '48h response time'] },
  { name: 'Pro', price: '$1,200/mo', features: ['Up to 10 hours/mo', 'New page builds', '24h response time', 'Monthly analytics review'] },
  { name: 'Agency', price: '$2,500/mo', features: ['Unlimited hours', 'Dedicated developer', 'Same-day response', 'Quarterly strategy call'] },
];
---

<Layout
  title="Pricing — Transparent Webflow Development Costs"
  description="Fixed-price Webflow development packages. No hidden fees, no hourly billing surprises. See exactly what you get."
>

  <div class="pt-32 pb-20 px-6">
    <div class="max-w-6xl mx-auto text-center">
      <p class="text-xs font-semibold text-white/30 uppercase tracking-widest mb-4">Pricing</p>
      <h1 class="text-5xl md:text-6xl font-bold text-white mb-6">Transparent. Fixed. No surprises.</h1>
      <p class="text-lg text-white/50 max-w-lg mx-auto">
        Every project is quoted upfront. You know exactly what you're paying before we start.
      </p>
    </div>
  </div>

  <!-- Project Packages -->
  <section class="py-20 px-6 border-t border-white/10">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-2xl font-bold text-white mb-10">Project packages</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {plans.map(plan => (
          <div class={`rounded-2xl p-8 flex flex-col ${plan.highlight ? 'card-inverted' : 'border border-white/10 text-white'}`}>
            <div class="mb-6">
              <p class={`text-xs font-semibold uppercase tracking-widest mb-2 ${plan.highlight ? 'card-inverted-muted' : 'text-white/30'}`}>{plan.name}</p>
              <p class="text-4xl font-bold">{plan.price}</p>
              <p class={`text-sm mt-1 ${plan.highlight ? 'card-inverted-muted' : 'text-white/40'}`}>{plan.unit}</p>
              <p class={`text-sm mt-3 leading-relaxed ${plan.highlight ? 'card-inverted-mid' : 'text-white/50'}`}>{plan.desc}</p>
            </div>
            <ul class="space-y-2 flex-1 mb-8">
              {plan.features.map(f => (
                <li class={`flex items-center gap-2 text-sm ${plan.highlight ? 'card-inverted-mid' : 'text-white/60'}`}>
                  <span class={plan.highlight ? '' : 'text-white/50'}>✓</span> {f}
                </li>
              ))}
            </ul>
            <a
              href="/contact"
              class={`text-center text-sm font-semibold py-3 rounded-full ${plan.highlight ? 'card-inverted-btn' : 'bg-white text-black hover:bg-white/90'}`}
            >
              {plan.cta} →
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Retainer Plans -->
  <section class="py-20 px-6 border-t border-white/10">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-2xl font-bold text-white mb-3">Support retainers</h2>
      <p class="text-white/50 mb-10 text-sm">Monthly plans for ongoing maintenance, updates, and support.</p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {retainer.map(r => (
          <div class="border border-white/10 rounded-2xl p-6">
            <p class="text-xs font-semibold text-white/30 uppercase tracking-widest mb-3">{r.name}</p>
            <p class="text-3xl font-bold text-white mb-4">{r.price}</p>
            <ul class="space-y-2">
              {r.features.map(f => (
                <li class="text-sm text-white/60 flex items-center gap-2">
                  <span class="text-white/50">✓</span> {f}
                </li>
              ))}
            </ul>
            <a href="/contact" class="mt-6 block text-center border border-white/20 text-white text-sm font-semibold py-2.5 rounded-full hover:bg-white/5">
              Get started →
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-20 px-6 border-t border-white/10">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-2xl font-bold text-white mb-10">Common questions</h2>
      <div class="space-y-6">
        {[
          { q: 'Do you charge hourly?', a: 'No. All projects are fixed-price. You know the total cost before we start. Scope changes are discussed and quoted separately.' },
          { q: 'What if I need something custom?', a: 'The Scale package and retainers are fully custom. Book a call and we\'ll scope it together.' },
          { q: 'What\'s not included?', a: 'Webflow hosting fees, third-party tool subscriptions (HubSpot, Mailchimp, etc.), and copywriting are not included unless agreed separately.' },
          { q: 'How long does a project take?', a: 'Starter: 1–2 weeks. Growth: 3–5 weeks. Scale: scoped per project. Timelines depend on content readiness.' },
          { q: 'Do I own the Webflow site?', a: 'Absolutely. The site is built in your Webflow account. You own 100% of the project and can manage it yourself after handoff.' },
        ].map(faq => (
          <div class="border-b border-white/10 pb-6">
            <p class="font-semibold text-white mb-2">{faq.q}</p>
            <p class="text-sm text-white/50">{faq.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

</Layout>
