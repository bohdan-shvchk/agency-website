---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contact — Start a Project"
  description="Tell us about your project. We respond within 24 hours."
>

  <div class="pt-32 pb-24 px-6">
    <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-16">

      <!-- Left: Info -->
      <div>
        <p class="text-xs font-semibold text-white/30 uppercase tracking-widest mb-4">Contact</p>
        <h1 class="text-5xl font-bold text-white mb-6 leading-tight">
          Let's build something great.
        </h1>
        <p class="text-white/50 leading-relaxed mb-10">
          We take on 3–4 new projects per month. Tell us what you're building and we'll get back to you within 24 hours.
        </p>

        <div class="space-y-6">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 border border-white/10 rounded-xl flex items-center justify-center flex-shrink-0">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-white/50">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>
              </svg>
            </div>
            <div>
              <p class="text-sm font-medium text-white">Email</p>
              <a href="mailto:hello@youragency.com" class="text-sm text-white/50 hover:text-white">hello@youragency.com</a>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-10 h-10 border border-white/10 rounded-xl flex items-center justify-center flex-shrink-0">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-white/50">
                <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/>
              </svg>
            </div>
            <div>
              <p class="text-sm font-medium text-white">LinkedIn</p>
              <a href="https://linkedin.com" target="_blank" rel="noopener" class="text-sm text-white/50 hover:text-white">linkedin.com/company/youragency</a>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-10 h-10 border border-white/10 rounded-xl flex items-center justify-center flex-shrink-0">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-white/50">
                <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
              </svg>
            </div>
            <div>
              <p class="text-sm font-medium text-white">Response time</p>
              <p class="text-sm text-white/50">Within 24 hours, Mon–Fri</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: Form -->
      <div class="border border-white/10 rounded-2xl p-8">
        <form
          action="https://formspree.io/f/YOUR_FORM_ID"
          method="POST"
          class="space-y-5"
        >
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-xs text-white/40 mb-2">First name</label>
              <input
                type="text"
                name="firstName"
                required
                class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-sm text-white placeholder-white/20 focus:outline-none focus:border-white/30"
                placeholder="John"
              />
            </div>
            <div>
              <label class="block text-xs text-white/40 mb-2">Last name</label>
              <input
                type="text"
                name="lastName"
                class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-sm text-white placeholder-white/20 focus:outline-none focus:border-white/30"
                placeholder="Doe"
              />
            </div>
          </div>

          <div>
            <label class="block text-xs text-white/40 mb-2">Email *</label>
            <input
              type="email"
              name="email"
              required
              class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-sm text-white placeholder-white/20 focus:outline-none focus:border-white/30"
              placeholder="john@company.com"
            />
          </div>

          <div>
            <label class="block text-xs text-white/40 mb-2">Company / Website</label>
            <input
              type="text"
              name="company"
              class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-sm text-white placeholder-white/20 focus:outline-none focus:border-white/30"
              placeholder="acme.com"
            />
          </div>

          <div>
            <label class="block text-xs text-white/40 mb-2">Service needed</label>
            <select
              name="service"
              class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-sm text-white/60 focus:outline-none focus:border-white/30 appearance-none"
            >
              <option value="">Select a service...</option>
              <option value="development">Webflow Development</option>
              <option value="integrations">Integrations & Automation</option>
              <option value="support">Support & Maintenance</option>
              <option value="other">Not sure yet</option>
            </select>
          </div>

          <div>
            <label class="block text-xs text-white/40 mb-2">Budget range</label>
            <select
              name="budget"
              class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-sm text-white/60 focus:outline-none focus:border-white/30 appearance-none"
            >
              <option value="">Select a range...</option>
              <option value="under2500">Under $2,500</option>
              <option value="2500-5500">$2,500 – $5,500</option>
              <option value="5500-10000">$5,500 – $10,000</option>
              <option value="10000+">$10,000+</option>
            </select>
          </div>

          <div>
            <label class="block text-xs text-white/40 mb-2">Tell us about your project *</label>
            <textarea
              name="message"
              required
              rows="4"
              class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-sm text-white placeholder-white/20 focus:outline-none focus:border-white/30 resize-none"
              placeholder="What are you building? What's the goal? Any timeline?"
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full bg-white text-black font-semibold py-3.5 rounded-full text-sm hover:bg-white/90"
          >
            Send message →
          </button>
        </form>
      </div>

    </div>
  </div>

</Layout>
