---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
);
const latestPosts = allPosts.slice(0, 3);

const allProjects = (await getCollection('projects')).sort(
  (a, b) => (a.data.order ?? 99) - (b.data.order ?? 99)
);

const now = new Date();
const oneWeekAgo = new Date(now.getTime() - 7 * 24 * 60 * 60 * 1000);
---

<Layout title="Your Agency — Webflow Development for Fast, Scalable Websites">

  <!-- Hero -->
  <section class="min-h-screen flex flex-col justify-center pt-24 pb-20 px-6">
    <div class="max-w-6xl mx-auto w-full">
      <div class="inline-flex items-center gap-2 border border-white/20 rounded-full px-4 py-1.5 text-xs text-white/60 mb-8">
        <span class="w-1.5 h-1.5 bg-green-400 rounded-full"></span>
        Available for new projects
      </div>
      <h1 class="text-5xl md:text-7xl font-bold text-white leading-[1.05] tracking-tight max-w-4xl">
        We build websites<br />
        <span class="text-white/30">that actually perform.</span>
      </h1>
      <p class="mt-8 text-lg text-white/50 max-w-xl leading-relaxed">
        Webflow development agency for startups and tech companies. Fast, scalable, high-performance websites — built to rank and convert.
      </p>
      <div class="mt-10 flex flex-wrap gap-4">
        <a href="/contact" class="bg-white text-black font-semibold px-7 py-3.5 rounded-full hover:bg-white/90 text-sm">
          Start a project
        </a>
        <a href="/projects" class="btn-outline border border-white/20 text-white font-semibold px-7 py-3.5 rounded-full hover:bg-white/5 text-sm">
          See our work
        </a>
      </div>

      <!-- Stats -->
      <div class="mt-20 grid grid-cols-2 md:grid-cols-4 gap-6 border-t border-white/10 pt-10">
        <div>
          <p class="text-3xl font-bold text-white">50+</p>
          <p class="text-sm text-white/40 mt-1">Projects delivered</p>
        </div>
        <div>
          <p class="text-3xl font-bold text-white">98</p>
          <p class="text-sm text-white/40 mt-1">Avg Lighthouse score</p>
        </div>
        <div>
          <p class="text-3xl font-bold text-white">3×</p>
          <p class="text-sm text-white/40 mt-1">Faster than WordPress</p>
        </div>
        <div>
          <p class="text-3xl font-bold text-white">5&#9733;</p>
          <p class="text-sm text-white/40 mt-1">Clutch rating</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="py-24 px-6 border-t border-white/10">
    <div class="max-w-6xl mx-auto">
      <p class="text-xs font-semibold text-white/30 uppercase tracking-widest mb-3">What we do</p>
      <h2 class="text-4xl font-bold text-white mb-16 max-w-xl">Three services. One focus — results.</h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <a href="/services#development" class="group border border-white/10 rounded-2xl p-8 hover:border-white/30 hover:bg-white/5">
          <div class="w-10 h-10 bg-white/10 rounded-xl flex items-center justify-center mb-6 group-hover:bg-white/20">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-white">
              <polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-white mb-2">Webflow Development</h3>
          <p class="text-sm text-white/50 leading-relaxed">
            Custom Webflow builds with clean architecture, blazing performance, and pixel-perfect design.
          </p>
          <p class="mt-6 text-sm text-white/30 group-hover:text-white flex items-center gap-1">Learn more →</p>
        </a>

        <a href="/services#integrations" class="group border border-white/10 rounded-2xl p-8 hover:border-white/30 hover:bg-white/5">
          <div class="w-10 h-10 bg-white/10 rounded-xl flex items-center justify-center mb-6 group-hover:bg-white/20">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-white">
              <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
              <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-white mb-2">Integrations & Automation</h3>
          <p class="text-sm text-white/50 leading-relaxed">
            Connect your site to CRM, email, analytics, and AI workflows. Automate what slows you down.
          </p>
          <p class="mt-6 text-sm text-white/30 group-hover:text-white flex items-center gap-1">Learn more →</p>
        </a>

        <a href="/services#support" class="group border border-white/10 rounded-2xl p-8 hover:border-white/30 hover:bg-white/5">
          <div class="w-10 h-10 bg-white/10 rounded-xl flex items-center justify-center mb-6 group-hover:bg-white/20">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-white">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-white mb-2">Support & Maintenance</h3>
          <p class="text-sm text-white/50 leading-relaxed">
            Ongoing retainer support. Updates, monitoring, and fixes — so you never worry about your site.
          </p>
          <p class="mt-6 text-sm text-white/30 group-hover:text-white flex items-center gap-1">Learn more →</p>
        </a>
      </div>
    </div>
  </section>

  <!-- Work Preview -->
  <section class="py-24 px-6 border-t border-white/10">
    <div class="max-w-6xl mx-auto">
      <div class="flex items-end justify-between mb-16">
        <div>
          <p class="text-xs font-semibold text-white/30 uppercase tracking-widest mb-3">Selected work</p>
          <h2 class="text-4xl font-bold text-white">Projects that speak.</h2>
        </div>
        <a href="/projects" class="text-sm text-white/50 hover:text-white hidden md:block">View all work →</a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {allProjects.map(project => (
          <a href={`/projects/${project.id}`} class="group border border-white/10 rounded-2xl overflow-hidden hover:border-white/30">
            <div class="aspect-video overflow-hidden" style="background-color: var(--surface-mid)">
              {project.data.preview
                ? <img src={project.data.preview} alt={project.data.title} class="w-full h-full object-cover object-top" />
                : <div class="w-full h-full flex items-center justify-center"><p class="text-white/20 text-xs font-semibold tracking-wide uppercase">{project.data.title}</p></div>
              }
            </div>
            <div class="p-6">
              <div class="flex items-center justify-between">
                <div>
                  <h3 class="font-semibold text-white">{project.data.title}</h3>
                  <p class="text-sm text-white/40 mt-1">{project.data.industry} · {project.data.services?.[0]}</p>
                </div>
                <span class="text-white/30 group-hover:text-white text-lg">↗</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Why us (addresses gaps from PRD) -->
  <section class="py-24 px-6 border-t border-white/10">
    <div class="max-w-6xl mx-auto">
      <p class="text-xs font-semibold text-white/30 uppercase tracking-widest mb-3">Why us</p>
      <h2 class="text-4xl font-bold text-white mb-16 max-w-xl">Everything your last agency missed.</h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="border border-white/10 rounded-2xl p-8">
          <p class="text-2xl mb-4">⚡</p>
          <h3 class="font-semibold text-white mb-2">Performance-first builds</h3>
          <p class="text-sm text-white/50">Every site ships with 95+ Lighthouse score. We don't cut corners on Core Web Vitals.</p>
        </div>
        <div class="border border-white/10 rounded-2xl p-8">
          <p class="text-2xl mb-4">🔍</p>
          <h3 class="font-semibold text-white mb-2">SEO from day one</h3>
          <p class="text-sm text-white/50">Sitemap, schema markup, meta tags, and clean HTML structure built into every project.</p>
        </div>
        <div class="border border-white/10 rounded-2xl p-8">
          <p class="text-2xl mb-4">🤖</p>
          <h3 class="font-semibold text-white mb-2">AI-ready integrations</h3>
          <p class="text-sm text-white/50">Automation workflows and AI agent integrations for teams that want to move fast in 2026.</p>
        </div>
        <div class="border border-white/10 rounded-2xl p-8">
          <p class="text-2xl mb-4">📊</p>
          <h3 class="font-semibold text-white mb-2">Results with receipts</h3>
          <p class="text-sm text-white/50">Every case study includes real metrics: load time, conversion rate, traffic growth. No vague "great results".</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Blog Preview -->
  <section class="py-24 px-6 border-t border-white/10">
    <div class="max-w-6xl mx-auto">
      <div class="flex items-end justify-between mb-16">
        <div>
          <p class="text-xs font-semibold text-white/30 uppercase tracking-widest mb-3">From the blog</p>
          <h2 class="text-4xl font-bold text-white">Latest writing.</h2>
        </div>
        <a href="/blog" class="text-sm text-white/50 hover:text-white hidden md:block">View all →</a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {latestPosts.map((post, index) => {
          const isLatest = index === 0;
          const isThisWeek = !isLatest && new Date(post.data.publishedAt) >= oneWeekAgo;
          return (
            <a href={`/blog/${post.id}`} class="group border border-white/10 rounded-2xl p-7 hover:border-white/30 hover:bg-white/5 flex flex-col">
              <div class="flex items-center gap-2 mb-4">
                {isLatest && (
                  <span class="text-xs font-semibold px-2.5 py-1 rounded-full bg-orange-500 text-white tracking-wide">NEW</span>
                )}
                {isThisWeek && (
                  <span class="text-xs font-semibold px-2.5 py-1 rounded-full bg-white text-black tracking-wide">THIS WEEK</span>
                )}
                <span class="text-xs border border-white/20 rounded-full px-3 py-1 text-white/50">{post.data.category}</span>
              </div>
              <h3 class="text-base font-semibold text-white leading-snug mb-3 flex-1">{post.data.title}</h3>
              <div class="flex items-center justify-between mt-4">
                <span class="text-xs text-white/30">
                  {new Date(post.data.publishedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                  &nbsp;·&nbsp;{post.data.readingTime} min
                </span>
                <span class="text-white/30 group-hover:text-white text-base">↗</span>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 px-6 border-t border-white/10">
    <div class="max-w-6xl mx-auto text-center">
      <h2 class="text-4xl md:text-6xl font-bold text-white mb-6">Ready to build something fast?</h2>
      <p class="text-white/50 text-lg mb-10 max-w-md mx-auto">Tell us about your project and we'll get back to you within 24 hours.</p>
      <a href="/contact" class="bg-white text-black font-semibold px-8 py-4 rounded-full text-sm hover:bg-white/90 inline-block">
        Start the conversation →
      </a>
    </div>
  </section>

</Layout>
