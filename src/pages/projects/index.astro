---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const allProjects = (await getCollection('projects')).sort(
  (a, b) => a.data.order - b.data.order
);
---

<Layout
  title="Work — Selected Projects | /shvchk"
  description="Real results, real metrics. Webflow projects built for startups and tech companies."
>

  <div class="pt-32 pb-20 px-6">
    <div class="max-w-6xl mx-auto">
      <p class="text-xs font-semibold text-white/30 uppercase tracking-widest mb-4">Work</p>
      <h1 class="text-5xl md:text-6xl font-bold text-white mb-6 max-w-2xl leading-tight">
        Results, not just screenshots.
      </h1>
      <p class="text-lg text-white/50 max-w-lg">
        Every case study includes real metrics: Lighthouse scores, load times, traffic growth. No fluff.
      </p>
    </div>
  </div>

  <section class="py-10 px-6 border-t border-white/10">
    <div class="max-w-6xl mx-auto space-y-4">
      {allProjects.map(project => (
        <a
          href={`/projects/${project.id}`}
          class="group flex flex-col md:flex-row border border-white/10 rounded-2xl overflow-hidden hover:border-white/30 hover:bg-white/5"
        >
          <!-- Color accent strip -->
          <div
            class="md:w-72 min-h-[160px] md:min-h-0 flex flex-col justify-between p-8 flex-shrink-0"
            style={`background-color: ${project.data.color}15; border-right: 1px solid ${project.data.color}30;`}
          >
            <div
              class="w-8 h-8 rounded-full"
              style={`background-color: ${project.data.color};`}
            ></div>
            <div class="mt-auto">
              <p class="text-xs text-white/30 mb-1">{project.data.year}</p>
              <p class="text-xs text-white/40">{project.data.industry}</p>
            </div>
          </div>

          <!-- Content -->
          <div class="p-8 flex flex-col justify-between flex-1">
            <div>
              <div class="flex flex-wrap gap-2 mb-4">
                {project.data.services.map(s => (
                  <span class="text-xs border border-white/20 rounded-full px-3 py-1 text-white/50">{s}</span>
                ))}
              </div>
              <h2 class="text-2xl font-bold text-white mb-2">{project.data.title}</h2>
              <p class="text-sm text-white/50 leading-relaxed">{project.data.tagline}</p>
            </div>

            <!-- Metrics preview -->
            {project.data.metrics && (
              <div class="mt-6 flex flex-wrap gap-6">
                {project.data.metrics.slice(0, 3).map(m => (
                  <div>
                    <p class="text-lg font-bold text-white">{m.value}</p>
                    <p class="text-xs text-white/40">{m.label}</p>
                  </div>
                ))}
              </div>
            )}

            <p class="mt-6 text-sm text-white/30 group-hover:text-white flex items-center gap-1">
              View case study →
            </p>
          </div>
        </a>
      ))}
    </div>
  </section>

  <section class="py-24 px-6 border-t border-white/10 mt-10">
    <div class="max-w-6xl mx-auto text-center">
      <h2 class="text-3xl font-bold text-white mb-4">Want to be next?</h2>
      <p class="text-white/50 mb-8">We're currently accepting new projects for Q2 2026.</p>
      <a href="/contact" class="bg-white text-black font-semibold px-8 py-4 rounded-full text-sm hover:bg-white/90 inline-block">
        Start a project →
      </a>
    </div>
  </section>

</Layout>
