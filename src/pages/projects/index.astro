---
import Layout from '../../layouts/Layout.astro';

const projects = [
  {
    slug: 'project-one',
    title: 'Client Name',
    category: 'EdTech',
    service: 'Webflow Development',
    desc: 'A full marketing site with CMS blog, Lighthouse score 98, 40% increase in organic traffic in 3 months.',
  },
  {
    slug: 'project-two',
    title: 'Client Name',
    category: 'SaaS',
    service: 'Integrations & Automation',
    desc: 'HubSpot CRM integration, automated lead routing, Zapier workflows saving 15 hours/week.',
  },
  {
    slug: 'project-three',
    title: 'Client Name',
    category: 'Immigration / RelocationTech',
    service: 'Webflow Development',
    desc: 'Multi-language Webflow site with custom CMS, deployed in 3 weeks. Page speed: 1.2s.',
  },
];
---

<Layout
  title="Work — Selected Webflow Projects"
  description="Real results, real metrics. Webflow projects we've built for startups and tech companies."
>

  <div class="pt-32 pb-24 px-6">
    <div class="max-w-6xl mx-auto">
      <p class="text-xs font-semibold text-white/30 uppercase tracking-widest mb-4">Work</p>
      <h1 class="text-5xl md:text-6xl font-bold text-white mb-6 max-w-2xl leading-tight">
        Results, not just screenshots.
      </h1>
      <p class="text-lg text-white/50 max-w-lg">
        Every case study includes real metrics: Lighthouse scores, load times, traffic growth. No fluff.
      </p>
    </div>
  </div>

  <section class="py-10 px-6 border-t border-white/10">
    <div class="max-w-6xl mx-auto space-y-6">
      {projects.map(project => (
        <a
          href={`/projects/${project.slug}`}
          class="group flex flex-col md:flex-row border border-white/10 rounded-2xl overflow-hidden hover:border-white/30"
        >
          <div class="bg-white/5 md:w-80 aspect-video md:aspect-auto flex items-center justify-center flex-shrink-0">
            <p class="text-white/20 text-sm">Screenshot</p>
          </div>
          <div class="p-8 flex flex-col justify-between flex-1">
            <div>
              <div class="flex items-center gap-3 mb-3">
                <span class="text-xs border border-white/20 rounded-full px-3 py-1 text-white/50">{project.category}</span>
                <span class="text-xs border border-white/20 rounded-full px-3 py-1 text-white/50">{project.service}</span>
              </div>
              <h2 class="text-2xl font-bold text-white mb-3">{project.title}</h2>
              <p class="text-white/50 text-sm leading-relaxed">{project.desc}</p>
            </div>
            <p class="mt-6 text-sm text-white/30 group-hover:text-white flex items-center gap-1">
              View case study →
            </p>
          </div>
        </a>
      ))}
    </div>
  </section>

  <section class="py-24 px-6 border-t border-white/10 mt-10">
    <div class="max-w-6xl mx-auto text-center">
      <h2 class="text-3xl font-bold text-white mb-4">Want to be next?</h2>
      <p class="text-white/50 mb-8">We're currently accepting new projects for Q2 2026.</p>
      <a href="/contact" class="bg-white text-black font-semibold px-8 py-4 rounded-full text-sm hover:bg-white/90 inline-block">
        Start a project →
      </a>
    </div>
  </section>

</Layout>
