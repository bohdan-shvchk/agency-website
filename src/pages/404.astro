---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="404 — Page not found | /shvchk"
  description="This page doesn't exist."
>
  <div class="min-h-screen flex flex-col items-center justify-center px-6 text-center">

    <!-- Big 404 -->
    <p class="text-[160px] md:text-[220px] font-bold leading-none text-white/5 select-none tracking-tighter">
      404
    </p>

    <div class="-mt-8 md:-mt-12 relative z-10">
      <p class="text-xs font-semibold text-white/30 uppercase tracking-widest mb-4">Page not found</p>
      <h1 class="text-3xl md:text-4xl font-bold text-white mb-4">
        This page doesn't exist.
      </h1>
      <p class="text-white/50 max-w-sm mx-auto mb-10 leading-relaxed">
        It may have been moved, deleted, or you may have mistyped the URL. Happens to the best of us.
      </p>

      <div class="flex flex-wrap gap-3 justify-center">
        <a href="/" class="bg-white text-black text-sm font-semibold px-6 py-3 rounded-full hover:bg-white/90">
          Go home
        </a>
        <a href="/projects" class="btn-outline border border-white/20 text-white text-sm font-semibold px-6 py-3 rounded-full hover:bg-white/5">
          View our work
        </a>
        <a href="/contact" class="btn-outline border border-white/20 text-white text-sm font-semibold px-6 py-3 rounded-full hover:bg-white/5">
          Contact us
        </a>
      </div>
    </div>

    <!-- Quick links -->
    <div class="mt-16 border-t border-white/10 pt-10 w-full max-w-md">
      <p class="text-xs text-white/30 uppercase tracking-widest mb-5">Maybe you were looking for</p>
      <div class="grid grid-cols-2 gap-2">
        {[
          { href: '/services', label: 'Services' },
          { href: '/projects', label: 'Work' },
          { href: '/blog', label: 'Blog' },
          { href: '/agency', label: 'About' },
        ].map(link => (
          <a
            href={link.href}
            class="border border-white/10 rounded-xl px-4 py-3 text-sm text-white/50 hover:text-white hover:border-white/30 text-left"
          >
            {link.label} →
          </a>
        ))}
      </div>
    </div>

  </div>
</Layout>
