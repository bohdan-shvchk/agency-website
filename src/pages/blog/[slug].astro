---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

const {
  title, description, publishedAt, updatedAt, author, authorRole, authorBio,
  authorLinkedIn, category, tags, readingTime, metaTitle, metaDescription,
  keyTakeaways, faq,
} = post.data;

const pageUrl = new URL(Astro.url.pathname, Astro.site).toString();
const formattedDate = publishedAt.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const tocHeadings = headings.filter(h => h.depth === 2 || h.depth === 3);

// BlogPosting JSON-LD
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  datePublished: publishedAt.toISOString(),
  dateModified: (updatedAt ?? publishedAt).toISOString(),
  author: { '@type': 'Person', name: author },
  publisher: { '@type': 'Organization', name: '/shvchk' },
  mainEntityOfPage: { '@type': 'WebPage', '@id': pageUrl },
  keywords: tags.join(', '),
};

const faqJsonLd = faq ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map(f => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer },
  })),
} : null;
---

<Layout
  title={metaTitle ?? title}
  description={metaDescription ?? description}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    {faqJsonLd && <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />}
    <meta property="og:type" content="article" />
    <meta property="article:published_time" content={publishedAt.toISOString()} />
    <meta property="article:author" content={author} />
    <meta property="article:section" content={category} />
  </Fragment>

  <div class="pt-28 pb-24 px-6">
    <div class="max-w-6xl mx-auto">

      <!-- Breadcrumbs -->
      <nav class="flex items-center gap-2 text-xs text-white/30 mb-10">
        <a href="/" class="hover:text-white">Home</a>
        <span>/</span>
        <a href="/blog" class="hover:text-white">Blog</a>
        <span>/</span>
        <span class="text-white/60 truncate max-w-xs">{title}</span>
      </nav>

      <div class="grid grid-cols-1 lg:grid-cols-[1fr_260px] gap-16 items-start">

        <!-- ── Main article ── -->
        <article>

          <!-- Header -->
          <header class="mb-10">
            <div class="flex items-center gap-3 mb-4">
              <span class="text-xs border border-white/20 rounded-full px-3 py-1 text-white/50">{category}</span>
              <span class="text-xs text-white/30">{formattedDate} · {readingTime} min read</span>
            </div>
            <h1 class="text-4xl md:text-5xl font-bold text-white leading-tight mb-5">{title}</h1>
            <div class="flex flex-wrap gap-2">
              {tags.map(tag => (
                <span class="text-xs text-white/30 bg-white/5 px-3 py-1 rounded-full">#{tag}</span>
              ))}
            </div>
          </header>

          <!-- Key Takeaways -->
          {keyTakeaways && keyTakeaways.length > 0 && (
            <div class="t-card p-6 mb-10">
              <p class="text-xs font-semibold t-text-faint uppercase tracking-widest mb-4">Key Takeaways</p>
              <ol class="space-y-2">
                {keyTakeaways.map((item, i) => (
                  <li class="flex gap-3 text-sm t-text-muted">
                    <span class="t-text-faint font-mono flex-shrink-0">{String(i + 1).padStart(2, '0')}.</span>
                    {item}
                  </li>
                ))}
              </ol>
            </div>
          )}

          <!-- Article body -->
          <div class="prose-article">
            <Content />
          </div>

          <!-- FAQ -->
          {faq && faq.length > 0 && (
            <div class="mt-14">
              <h2 class="text-2xl font-bold text-white mb-6">Frequently Asked Questions</h2>
              <div class="space-y-3" id="faq-accordion">
                {faq.map((item, i) => (
                  <div class="faq-item border border-white/10 rounded-2xl overflow-hidden">
                    <button
                      class="faq-trigger w-full flex items-center justify-between px-6 py-4 text-left text-sm font-semibold text-white hover:bg-white/5"
                      aria-expanded="false"
                      data-index={i}
                    >
                      {item.question}
                      <svg class="faq-icon flex-shrink-0 ml-4 transition-transform" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="6 9 12 15 18 9"/>
                      </svg>
                    </button>
                    <div class="faq-answer hidden px-6 pb-4 text-sm text-white/60 leading-relaxed">
                      {item.answer}
                    </div>
                  </div>
                ))}
              </div>
            </div>
          )}

          <!-- Author -->
          <div class="mt-14 border border-white/10 rounded-2xl p-6 flex gap-5 items-start">
            <div class="w-14 h-14 rounded-full bg-white/10 flex-shrink-0 flex items-center justify-center text-white/40 text-xl font-bold">
              {author[0]}
            </div>
            <div>
              <p class="text-xs text-white/30 uppercase tracking-widest mb-1">Written by</p>
              <p class="font-semibold text-white">{author}</p>
              <p class="text-sm text-white/50 mb-2">{authorRole}</p>
              {authorBio && <p class="text-sm text-white/40 leading-relaxed">{authorBio}</p>}
              {authorLinkedIn && (
                <a href={authorLinkedIn} target="_blank" rel="noopener" class="mt-3 inline-block text-xs text-white/30 hover:text-white">
                  LinkedIn ↗
                </a>
              )}
            </div>
          </div>

          <!-- Back -->
          <div class="mt-10">
            <a href="/blog" class="text-sm text-white/40 hover:text-white">← Back to Blog</a>
          </div>

        </article>

        <!-- ── Sidebar ── -->
        <aside class="hidden lg:block sticky top-28 space-y-6">

          <!-- Table of Contents -->
          {tocHeadings.length > 0 && (
            <div class="border border-white/10 rounded-2xl p-5">
              <p class="text-xs font-semibold text-white/30 uppercase tracking-widest mb-4">Contents</p>
              <nav>
                <ul class="space-y-1" id="toc-list">
                  {tocHeadings.map(h => (
                    <li>
                      <a
                        href={`#${h.slug}`}
                        data-heading={h.slug}
                        class={`toc-link block text-sm py-1 text-white/40 hover:text-white leading-snug ${h.depth === 3 ? 'pl-3' : ''}`}
                      >
                        {h.text}
                      </a>
                    </li>
                  ))}
                </ul>
              </nav>
            </div>
          )}

          <!-- Share -->
          <div class="border border-white/10 rounded-2xl p-5">
            <p class="text-xs font-semibold text-white/30 uppercase tracking-widest mb-4">Share</p>
            <div class="flex gap-2">
              <a
                href={`https://twitter.com/intent/tweet?url=${encodeURIComponent(pageUrl)}&text=${encodeURIComponent(title)}`}
                target="_blank" rel="noopener"
                class="flex-1 text-center text-xs border border-white/20 rounded-xl py-2 text-white/50 hover:text-white hover:border-white/40"
              >
                Twitter/X
              </a>
              <a
                href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(pageUrl)}`}
                target="_blank" rel="noopener"
                class="flex-1 text-center text-xs border border-white/20 rounded-xl py-2 text-white/50 hover:text-white hover:border-white/40"
              >
                LinkedIn
              </a>
            </div>
          </div>

          <!-- Tags -->
          {tags.length > 0 && (
            <div class="border border-white/10 rounded-2xl p-5">
              <p class="text-xs font-semibold text-white/30 uppercase tracking-widest mb-4">Tags</p>
              <div class="flex flex-wrap gap-2">
                {tags.map(tag => (
                  <span class="text-xs text-white/40 bg-white/5 px-3 py-1 rounded-full">#{tag}</span>
                ))}
              </div>
            </div>
          )}

        </aside>

      </div>
    </div>
  </div>

</Layout>

<style is:global>
  /* Article body typography */
  .prose-article h2 {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--fg);
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    scroll-margin-top: 6rem;
  }
  .prose-article h3 {
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--fg);
    margin-top: 2rem;
    margin-bottom: 0.5rem;
    scroll-margin-top: 6rem;
  }
  .prose-article p {
    color: color-mix(in srgb, var(--fg) 60%, transparent);
    line-height: 1.8;
    margin-bottom: 1.25rem;
    font-size: 0.975rem;
  }
  .prose-article ul, .prose-article ol {
    margin: 1rem 0 1.25rem 1.25rem;
    color: color-mix(in srgb, var(--fg) 60%, transparent);
    font-size: 0.975rem;
  }
  .prose-article li { margin-bottom: 0.4rem; line-height: 1.7; }
  .prose-article strong { color: var(--fg); font-weight: 600; }
  .prose-article a { color: var(--fg); text-decoration: underline; text-underline-offset: 3px; opacity: 0.8; }
  .prose-article a:hover { opacity: 1; }
  .prose-article blockquote {
    border-left: 3px solid rgba(255,255,255,0.2);
    padding: 0.5rem 1rem;
    margin: 1.5rem 0;
    color: color-mix(in srgb, var(--fg) 50%, transparent);
    font-style: italic;
  }
  .prose-article code {
    background: rgba(255,255,255,0.08);
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: 0.85em;
  }
  .prose-article pre {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 12px;
    padding: 1.25rem;
    overflow-x: auto;
    margin: 1.5rem 0;
  }
  .prose-article pre code {
    background: none;
    padding: 0;
    font-size: 0.875rem;
    line-height: 1.7;
  }
  .prose-article hr {
    border: none;
    border-top: 1px solid rgba(255,255,255,0.1);
    margin: 2rem 0;
  }
  .prose-article table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-size: 0.9rem;
  }
  .prose-article th {
    background: rgba(255,255,255,0.08);
    color: var(--fg);
    padding: 0.6rem 0.9rem;
    text-align: left;
    font-weight: 600;
    border: 1px solid rgba(255,255,255,0.1);
  }
  .prose-article td {
    padding: 0.6rem 0.9rem;
    border: 1px solid rgba(255,255,255,0.08);
    color: color-mix(in srgb, var(--fg) 60%, transparent);
  }
  /* Callout blocks */
  .prose-article .callout, [data-callout] {
    border-radius: 12px;
    padding: 1rem 1.25rem;
    margin: 1.5rem 0;
    font-size: 0.9rem;
  }
  /* Astro remark callout: :::tip :::warning :::info */
  .prose-article blockquote p:first-child strong { display: block; margin-bottom: 0.3rem; }

  /* Light theme overrides for prose */
  [data-theme="light"] .prose-article code { background: rgba(0,0,0,0.06); }
  [data-theme="light"] .prose-article pre { background: rgba(0,0,0,0.04); border-color: rgba(0,0,0,0.1); }
  [data-theme="light"] .prose-article th { background: rgba(0,0,0,0.06); border-color: rgba(0,0,0,0.1); }
  [data-theme="light"] .prose-article td { border-color: rgba(0,0,0,0.07); }
  [data-theme="light"] .prose-article blockquote { border-color: rgba(0,0,0,0.2); }
</style>

<script>
  // ── TOC active heading via IntersectionObserver ──
  const tocLinks = document.querySelectorAll<HTMLAnchorElement>('.toc-link');

  if (tocLinks.length > 0) {
    const headingEls = Array.from(tocLinks).map(l =>
      document.getElementById(l.dataset.heading!)
    ).filter(Boolean) as HTMLElement[];

    const observer = new IntersectionObserver(entries => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          tocLinks.forEach(l => l.classList.remove('text-white', 'font-medium'));
          const active = document.querySelector<HTMLAnchorElement>(
            `.toc-link[data-heading="${entry.target.id}"]`
          );
          active?.classList.add('text-white', 'font-medium');
          active?.classList.remove('text-white/40');
        }
      });
    }, { rootMargin: '-80px 0px -70% 0px', threshold: 0 });

    headingEls.forEach(el => observer.observe(el));
  }

  // ── FAQ accordion ──
  document.querySelectorAll<HTMLButtonElement>('.faq-trigger').forEach(btn => {
    btn.addEventListener('click', () => {
      const answer = btn.nextElementSibling as HTMLElement;
      const icon = btn.querySelector('.faq-icon') as HTMLElement;
      const isOpen = btn.getAttribute('aria-expanded') === 'true';

      btn.setAttribute('aria-expanded', String(!isOpen));
      answer.classList.toggle('hidden', isOpen);
      icon.style.transform = isOpen ? '' : 'rotate(180deg)';
    });
  });
</script>
