---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
);

const categories = ['All', ...new Set(allPosts.map(p => p.data.category))];

const now = new Date();
const oneWeekAgo = new Date(now.getTime() - 7 * 24 * 60 * 60 * 1000);
---

<Layout
  title="Blog — Web Development, AI & Agency Insights"
  description="Honest writing on web development, AI tools, Webflow, Shopify, and everything in between."
>

  <div class="pt-32 pb-20 px-6">
    <div class="max-w-6xl mx-auto">
      <p class="text-xs font-semibold text-white/30 uppercase tracking-widest mb-4">Blog</p>
      <h1 class="text-5xl font-bold text-white mb-4">Honest writing on the web.</h1>
      <p class="text-lg text-white/50 max-w-lg">
        Practical takes on web development, AI tools, Webflow, Shopify, and what actually works in 2026.
      </p>
    </div>
  </div>

  <section class="py-10 px-6 border-t border-white/10">
    <div class="max-w-6xl mx-auto">

      <!-- Category filter -->
      <div class="flex flex-wrap gap-2 mb-10" id="category-filter">
        {categories.map(cat => (
          <button
            data-category={cat}
            class={`category-btn text-xs px-4 py-1.5 rounded-full border transition-colors ${cat === 'All' ? 'bg-white text-black border-white' : 'border-white/20 text-white/50 hover:border-white/40 hover:text-white'}`}
          >
            {cat}
          </button>
        ))}
      </div>

      <!-- Posts list -->
      <div class="space-y-4" id="posts-list">
        {allPosts.map(post => (
          <a
            href={`/blog/${post.id}`}
            data-category={post.data.category}
            class="post-card group flex flex-col md:flex-row md:items-center justify-between border border-white/10 rounded-2xl p-8 hover:border-white/30 hover:bg-white/5 gap-4"
          >
            <div class="flex-1">
              <div class="flex items-center gap-3 mb-3">
                <span class="text-xs border border-white/20 rounded-full px-3 py-1 text-white/50">
                  {post.data.category}
                </span>
                {new Date(post.data.publishedAt) >= oneWeekAgo && (
                  <span class="text-xs font-semibold px-2.5 py-1 rounded-full bg-white text-black tracking-wide">NEW</span>
                )}
                <span class="text-xs text-white/30">
                  {post.data.publishedAt.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
                  &nbsp;·&nbsp;{post.data.readingTime} min read
                </span>
              </div>
              <h2 class="text-xl font-bold text-white mb-2">{post.data.title}</h2>
              <p class="text-sm text-white/50">{post.data.description}</p>
              <div class="flex gap-2 mt-3 flex-wrap">
                {post.data.tags.map(tag => (
                  <span class="text-xs text-white/30">#{tag}</span>
                ))}
              </div>
            </div>
            <span class="text-white/30 group-hover:text-white text-xl flex-shrink-0">↗</span>
          </a>
        ))}
      </div>

    </div>
  </section>

</Layout>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.category-btn');
  const cards = document.querySelectorAll<HTMLElement>('.post-card');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const selected = btn.dataset.category!;

      // Update button styles
      buttons.forEach(b => {
        const active = b.dataset.category === selected;
        b.classList.toggle('bg-white', active);
        b.classList.toggle('text-black', active);
        b.classList.toggle('border-white', active);
        b.classList.toggle('text-white/50', !active);
        b.classList.toggle('border-white/20', !active);
      });

      // Filter cards
      cards.forEach(card => {
        const show = selected === 'All' || card.dataset.category === selected;
        card.style.display = show ? '' : 'none';
      });
    });
  });
</script>
